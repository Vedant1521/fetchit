{
  "name": "@vedant1521/fetchit",
  "version": "0.5.0",
  "description": "grab any video from YouTube, X, Instagram, Threads & 2000+ sites — right from your terminal. paste. fetch. done.",
  "type": "module",
  "bin": {
    "fetchit": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "build:sea": "tsup --config tsup.sea.ts && node --experimental-sea-config sea-config.json",
    "build:binary": "bun scripts/build-binary.js",
    "build:binary:all": "bun scripts/build-binary.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm test && npm run typecheck && npm run build"
  },
  "author": "Vedant Gupta",
  "keywords": [
    "video",
    "downloader",
    "yt-dlp",
    "youtube",
    "instagram",
    "twitter",
    "threads",
    "cli",
    "tui",
    "ink"
  ],
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vedant1521/fetchit.git"
  },
  "homepage": "https://github.com/Vedant1521/fetchit#readme",
  "bugs": {
    "url": "https://github.com/Vedant1521/fetchit/issues"
  }
}
