{
  "rootDirectory": "site",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/install.sh",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/x-shellscript"
        }
      ]
    },
    {
      "source": "/install.ps1",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/powershell"
        }
      ]
    }
  ]
}
